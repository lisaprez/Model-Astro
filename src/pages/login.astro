---
import crypto from 'crypto';

// Génère un token côté build (simulation)
const token = crypto.randomBytes(16).toString('hex');
const magicLink = `/magic?token=${token}`;
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Connexion</title>
  </head>
  <body>
    <h1>Connexion par lien magique</h1>

    <form onsubmit="event.preventDefault(); generateLink();">
      <label for="email">Email :</label><br />
      <input type="email" id="email" required /><br /><br />
      <button type="submit">Générer le lien magique</button>
    </form>

    <div id="result" style="margin-top:2em;color:green;"></div>

    <script>
      function generateLink() {
        const email = document.getElementById('email').value;
        if (!email) return;

        const token = Math.random().toString(36).substring(2);
        const link = `/magic?token=${token}`;

        document.getElementById('result').innerHTML =
          "Lien magique : <a href='" + link + "'>" + link + "</a>";
      }
    </script>
  </body>
</html>