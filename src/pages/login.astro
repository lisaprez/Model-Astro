
import crypto from 'crypto';

let message = '';
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email');
  if (email) {
    // Génère un token factice
    const token = crypto.randomBytes(16).toString('hex');
    // Affiche le lien magique (simulation d'envoi par email)
    message = `Lien magique généré : <a href='/magic?token=${token}'>/magic?token=${token}</a>`;
  }
}

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Connexion</title>
  </head>
  <body>
    <h1>Connexion par lien magique</h1>
    <form method="post">
      <label for="email">Email :</label><br />
      <input type="email" id="email" name="email" required /><br /><br />
      <button type="submit">Envoyer le lien magique</button>
    </form>
    <div style="margin-top:2em;color:green;">{message && Astro.raw(message)}</div>
  </body>
</html>
